# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# VITE_GEMINI_API_KEY: Required for STATIC (Netlify/Vercel) client-only deployments.
# If you deploy to a static host without Node.js backend support, you MUST add this 
# environment variable to enable client-side AI fallback.
VITE_GEMINI_API_KEY=

# OPENROUTER_API_KEY: Required for OpenRouter LLM API calls.
# Configure this via the Secrets panel in the AI Studio UI to enable OpenRouter responses.
OPENROUTER_API_KEY=

# OPENROUTER_MODEL: The model to use for OpenRouter API (e.g. google/gemini-2.5-flash)
OPENROUTER_MODEL=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# SUPABASE
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=




